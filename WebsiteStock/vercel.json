{
  "version": 2,
  "builds": [
    {
      "src": "api/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/app.py"
    },

    {
      "src": "/stock/([^/]+)",
      "dest": "api/app.py"
    },
    {
      "src": "/backtest/([^/]+)",
      "dest": "api/app.py"
    },
    {
      "src": "/sr/([^/]+)",
      "dest": "api/app.py"
    },
    {
      "src": "/volume/([^/]+)",
      "dest": "api/app.py"
    },
    {
      "src": "/scan/([^/]*)",
      "dest": "api/app.py"
    },
    {
      "src": "/market-scan",
      "dest": "api/app.py"
    },
    {
      "src": "/sectors",
      "dest": "api/app.py"
    },

    {
      "src": "/style\\.css",
      "dest": "public/style.css"
    },
    {
      "src": "/script\\.js",
      "dest": "public/script.js"
    },
    {
      "src": "/config\\.js",
      "dest": "public/config.js"
    },

    {
      "src": "/screener\\.html",
      "dest": "public/screener.html"
    },
    {
      "src": "/screener",
      "dest": "public/screener.html"
    },
    {
      "src": "/scanner\\.html",
      "dest": "public/scanner.html"
    },
    {
      "src": "/scanner",
      "dest": "public/scanner.html"
    },
    {
      "src": "/sr\\.html",
      "dest": "public/sr.html"
    },
    {
      "src": "/sr",
      "dest": "public/sr.html"
    },
    {
      "src": "/volume\\.html",
      "dest": "public/volume.html"
    },
    {
      "src": "/volume",
      "dest": "public/volume.html"
    },
    {
      "src": "/foreign\\.html",
      "dest": "public/foreign.html"
    },
    {
      "src": "/foreign",
      "dest": "public/foreign.html"
    },
    {
      "src": "/ai-signal\\.html",
      "dest": "public/ai-signal.html"
    },
    {
      "src": "/ai-signal",
      "dest": "public/ai-signal.html"
    },
    {
      "src": "/news\\.html",
      "dest": "public/news.html"
    },
    {
      "src": "/news",
      "dest": "public/news.html"
    },
    {
      "src": "/kalender\\.html",
      "dest": "public/kalender.html"
    },
    {
      "src": "/kalender",
      "dest": "public/kalender.html"
    },
    {
      "src": "/index\\.html",
      "dest": "public/index.html"
    },
    {
      "src": "/",
      "dest": "public/index.html"
    },

    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}